# gemini-mcp-server environment variables
# Copy to `.env` (loaded by your process manager / MCP client) and edit as needed.
# Only GEMINI_API_KEY is required; everything else has sensible defaults.

# --- Required ---

# Google Gemini API key. The server fails to start if this is unset.
# Get one from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key

# --- Default models (per-tool, optional) ---
# These are pre-optimized per use case; override only with a clear reason.

GEMINI_MODEL=gemini-3.5-flash               # gemini_chat
GEMINI_AGENT_MODEL=gemini-3.5-flash         # gemini_custom_agent
GEMINI_SEARCH_MODEL=gemini-3.1-flash-lite   # gemini_search
GEMINI_VISION_MODEL=gemini-3.1-flash-lite   # gemini_analyze_media
GEMINI_CODE_MODEL=gemini-3.1-flash-lite     # gemini_execute_code
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview  # gemini_generate_image

# --- Default thinking levels (optional) ---
# One of: minimal | low | medium | high

GEMINI_THINKING_LEVEL=medium
GEMINI_AGENT_THINKING_LEVEL=high
GEMINI_VISION_THINKING_LEVEL=medium
GEMINI_CODE_THINKING_LEVEL=low
GEMINI_IMAGE_THINKING_LEVEL=medium

# --- Behavior (optional) ---

# Request timeout in seconds.
GEMINI_TIMEOUT=360

# Default inference tier: flex | priority | standard (omit for the API default).
# GEMINI_SERVICE_TIER=flex

# Default output directory for gemini_generate_image (defaults to <tmpdir>/mcp-gemini/imagen).
# IMAGEN_OUTPUT_DIR=/var/lib/imagen

# Log level (logs go to stderr only). e.g. info | debug | warn | error
LOG_LEVEL=info
